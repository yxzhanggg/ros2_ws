<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="nexus_sentinel">
  <xacro:arg name="use_sim" default="true"/>

  <xacro:property name="base_length" value="0.72"/>
  <xacro:property name="base_width" value="0.48"/>
  <xacro:property name="base_height" value="0.18"/>
  <xacro:property name="wheel_radius" value="0.095"/>
  <xacro:property name="wheel_width" value="0.055"/>
  <xacro:property name="wheel_separation" value="0.54"/>
  <xacro:property name="caster_radius" value="0.035"/>
  <material name="sentinel_charcoal">
    <color rgba="0.07 0.08 0.09 1.0"/>
  </material>
  <material name="sentinel_blue">
    <color rgba="0.05 0.35 0.85 1.0"/>
  </material>
  <material name="sentinel_silver">
    <color rgba="0.62 0.67 0.72 1.0"/>
  </material>
  <material name="sentinel_rubber">
    <color rgba="0.01 0.01 0.012 1.0"/>
  </material>

  <xacro:macro name="box_inertia" params="mass x y z">
    <inertial>
      <mass value="${mass}"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia
        ixx="${mass * (y * y + z * z) / 12.0}"
        ixy="0.0"
        ixz="0.0"
        iyy="${mass * (x * x + z * z) / 12.0}"
        iyz="0.0"
        izz="${mass * (x * x + y * y) / 12.0}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_inertia" params="mass radius length axis">
    <inertial>
      <mass value="${mass}"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <xacro:if value="${axis == 'x'}">
        <inertia
          ixx="${0.5 * mass * radius * radius}"
          ixy="0.0"
          ixz="0.0"
          iyy="${mass * (3.0 * radius * radius + length * length) / 12.0}"
          iyz="0.0"
          izz="${mass * (3.0 * radius * radius + length * length) / 12.0}"/>
      </xacro:if>
      <xacro:if value="${axis == 'z'}">
        <inertia
          ixx="${mass * (3.0 * radius * radius + length * length) / 12.0}"
          ixy="0.0"
          ixz="0.0"
          iyy="${mass * (3.0 * radius * radius + length * length) / 12.0}"
          iyz="0.0"
          izz="${0.5 * mass * radius * radius}"/>
      </xacro:if>
    </inertial>
  </xacro:macro>

  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${base_height / 2.0}" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="sentinel_charcoal"/>
    </visual>
    <collision>
      <origin xyz="0 0 ${base_height / 2.0}" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertia mass="16.0" x="${base_length}" y="${base_width}" z="${base_height}"/>
  </link>

  <link name="top_deck_link">
    <visual>
      <origin xyz="0 0 0.245" rpy="0 0 0"/>
      <geometry>
        <box size="0.54 0.36 0.035"/>
      </geometry>
      <material name="sentinel_blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.245" rpy="0 0 0"/>
      <geometry>
        <box size="0.54 0.36 0.035"/>
      </geometry>
    </collision>
    <xacro:box_inertia mass="1.2" x="0.54" y="0.36" z="0.035"/>
  </link>

  <joint name="top_deck_joint" type="fixed">
    <parent link="base_link"/>
    <child link="top_deck_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <xacro:macro name="drive_wheel" params="prefix y_sign">
    <link name="${prefix}_wheel_link">
      <visual>
        <origin xyz="0 0 0" rpy="${pi / 2.0} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
        <material name="sentinel_rubber"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="${pi / 2.0} 0 0"/>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
        </geometry>
      </collision>
      <xacro:cylinder_inertia mass="1.2" radius="${wheel_radius}" length="${wheel_width}" axis="x"/>
    </link>
    <joint name="${prefix}_wheel_joint" type="continuous">
      <parent link="base_link"/>
      <child link="${prefix}_wheel_link"/>
      <origin xyz="0 ${y_sign * wheel_separation / 2.0} 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit effort="12.0" velocity="18.0"/>
      <dynamics damping="0.02" friction="0.01"/>
    </joint>
  </xacro:macro>

  <xacro:drive_wheel prefix="left" y_sign="1"/>
  <xacro:drive_wheel prefix="right" y_sign="-1"/>

  <xacro:macro name="caster" params="prefix x">
    <link name="${prefix}_caster_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <sphere radius="${caster_radius}"/>
        </geometry>
        <material name="sentinel_silver"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <geometry>
          <sphere radius="${caster_radius}"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.18"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <inertia ixx="0.00009" ixy="0.0" ixz="0.0" iyy="0.00009" iyz="0.0" izz="0.00009"/>
      </inertial>
    </link>
    <joint name="${prefix}_caster_joint" type="fixed">
      <parent link="base_link"/>
      <child link="${prefix}_caster_link"/>
      <origin xyz="${x} 0 ${-wheel_radius + caster_radius}" rpy="0 0 0"/>
    </joint>
  </xacro:macro>

  <xacro:caster prefix="front" x="0.28"/>
  <xacro:caster prefix="rear" x="-0.28"/>

  <link name="laser_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.055" length="0.055"/>
      </geometry>
      <material name="sentinel_silver"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.055" length="0.055"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia mass="0.25" radius="0.055" length="0.055" axis="z"/>
  </link>

  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_link"/>
    <origin xyz="0.18 0 0.32" rpy="0 0 0"/>
  </joint>

  <link name="camera_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.08 0.045 0.045"/>
      </geometry>
      <material name="sentinel_blue"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.08 0.045 0.045"/>
      </geometry>
    </collision>
    <xacro:box_inertia mass="0.18" x="0.08" y="0.045" z="0.045"/>
  </link>

  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <origin xyz="0.38 0 0.25" rpy="0 0 0"/>
  </joint>

  <link name="camera_optical_frame"/>
  <joint name="camera_optical_joint" type="fixed">
    <parent link="camera_link"/>
    <child link="camera_optical_frame"/>
    <origin xyz="0.045 0 0" rpy="${-pi / 2.0} 0 ${-pi / 2.0}"/>
  </joint>

  <link name="imu_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.055 0.04 0.02"/>
      </geometry>
      <material name="sentinel_silver"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.055 0.04 0.02"/>
      </geometry>
    </collision>
    <xacro:box_inertia mass="0.08" x="0.055" y="0.04" z="0.02"/>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="0 0 0.22" rpy="0 0 0"/>
  </joint>

  <gazebo reference="base_link">
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  <gazebo reference="top_deck_link">
    <material>Gazebo/Blue</material>
  </gazebo>
  <gazebo reference="left_wheel_link">
    <material>Gazebo/Black</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>
  <gazebo reference="right_wheel_link">
    <material>Gazebo/Black</material>
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
  </gazebo>

  <gazebo reference="laser_link">
    <sensor name="front_lidar" type="gpu_lidar">
      <topic>scan</topic>
      <update_rate>12</update_rate>
      <ray>
        <scan>
          <horizontal>
            <samples>720</samples>
            <resolution>1</resolution>
            <min_angle>-3.14159</min_angle>
            <max_angle>3.14159</max_angle>
          </horizontal>
        </scan>
        <range>
          <min>0.08</min>
          <max>12.0</max>
          <resolution>0.01</resolution>
        </range>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.01</stddev>
        </noise>
      </ray>
      <always_on>true</always_on>
      <visualize>true</visualize>
    </sensor>
  </gazebo>

  <gazebo reference="camera_link">
    <sensor name="front_camera" type="camera">
      <topic>camera</topic>
      <update_rate>15</update_rate>
      <camera>
        <horizontal_fov>1.3962634</horizontal_fov>
        <image>
          <width>640</width>
          <height>480</height>
          <format>R8G8B8</format>
        </image>
        <clip>
          <near>0.05</near>
          <far>30.0</far>
        </clip>
      </camera>
      <always_on>true</always_on>
      <visualize>true</visualize>
    </sensor>
  </gazebo>

  <gazebo reference="imu_link">
    <sensor name="base_imu" type="imu">
      <topic>imu</topic>
      <update_rate>50</update_rate>
      <always_on>true</always_on>
    </sensor>
  </gazebo>

  <ros2_control name="SentinelGazeboSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>
    <joint name="left_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="right_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <gazebo>
    <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <ros>
        <namespace>/</namespace>
      </ros>
    </plugin>
  </gazebo>

  <!-- URDF 1.2 compatibility note:
       The Lyrical parser on nexus is validated against standard rpy origins here.
       Sensor joints are zero-rotation mounts and equivalent to quat_xyzw="0 0 0 1";
       capsule collision support is tracked in docs/DEPENDENCIES.md after parser checks. -->
</robot>
